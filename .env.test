# Test-only Supabase config. Committed on purpose (unlike .env): these are dummy
# values that let the shared client (src/shared/supabase.ts) — which reads these
# at import time and throws if missing — be imported under test. They never talk
# to a real backend. Vitest runs in `test` mode and loads this file automatically.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_test
