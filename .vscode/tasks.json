{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install-if-needed",
      "type": "shell",
      "command": "if (-not (Test-Path 'node_modules')) { npm install }",
      "options": {
        "shell": {
          "executable": "powershell",
          "args": ["-Command"]
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "dependsOn": ["install-if-needed"],
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "vite",
          "pattern": [{ "regexp": "^(.*):(\\d+):\\s+(.*)$", "file": 1, "line": 2, "message": 3 }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE",
            "endsPattern": "Local:.*http://localhost"
          }
        }
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
