# Copy this file to `.env` and fill in your values.
# `.env` is gitignored. Anything with a VITE_ prefix is bundled into the
# client and is PUBLICLY VISIBLE.

# Supabase (persistence + authentication). The publishable key is bundled into
# the client and is PUBLICLY VISIBLE by design — data is protected by Row Level
# Security, not key secrecy. Use the publishable key (sb_publishable_...), never
# a secret key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# NOTE: access control (who may save characters) is NOT configured here. Sign-in
# is Discord-only, and a user is promoted from 'guest' to 'user' when they belong
# to an allowed Discord server. The allow-list of server (guild) ids lives
# SERVER-SIDE as an Edge Function secret in Supabase (DISCORD_ALLOWED_GUILD_IDS),
# never as a VITE_ var — a client-bundled list would be public and unenforceable.
# See README "Deployment" for the GitHub secrets that sync it.
