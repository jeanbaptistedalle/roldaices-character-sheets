# Copy this file to `.env` and fill in your values.
# `.env` is gitignored. Anything with a VITE_ prefix is bundled into the
# client and is PUBLICLY VISIBLE — only use a RESTRICTED RestDB API key here
# (scoped to the character collection, minimal permissions).

# Base URL of your RestDB database, e.g. https://yourdb-xxxx.restdb.io/rest
VITE_RESTDB_URL=

# Restricted RestDB API key (NOT a full-access key)
VITE_RESTDB_API_KEY=

# Supabase (authentication). The publishable key is bundled into the client and
# is PUBLICLY VISIBLE by design — data is protected by Row Level Security, not
# key secrecy. Use the publishable key (sb_publishable_...), never a secret key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
